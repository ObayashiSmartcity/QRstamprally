<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <title>簡易スタンプラリー</title>
    <style>
        body { font-family: sans-serif; text-align: center; padding: 20px; }
        .grid { display: flex; justify-content: center; gap: 20px; margin-top: 20px; }
        .stamp { width: 80px; height: 80px; border: 2px dashed #ccc; border-radius: 50%; line-height: 80px; color: #ccc; font-weight: bold; }
        .stamp.active { border: 2px solid #ff4757; color: #ff4757; background-color: #ffeaa7; }
    </style>
</head>
<body>

    <h1>デジタルスタンプラリー</h1>
    <p id="message">スポットを巡ってスタンプを集めよう！</p>

    <div class="grid">
        <div id="spot1" class="stamp">スポット1</div>
        <div id="spot2" class="stamp">スポット2</div>
        <div id="spot3" class="stamp">スポット3</div>
    </div>

    <script>
        // 1. ローカルストレージから現在の進捗を読み込む（なければ空のオブジェクト）
        let progress = JSON.parse(localStorage.getItem('stamp_rally_progress')) || {};

        // 2. URLのパラメータ（例: ?spot=spot1）をチェックする
        const urlParams = new URLSearchParams(window.location.search);
        const currentSpot = urlParams.get('spot');

        // 3. もしスポットのパラメータがあれば、進捗を「獲得済」にして保存
        if (currentSpot && ['spot1', 'spot2', 'spot3'].includes(currentSpot)) {
            progress[currentSpot] = true;
            localStorage.setItem('stamp_rally_progress', JSON.stringify(progress));
            document.getElementById('message').innerText = `${currentSpot} のスタンプをゲットしました！`;
        }

        // 4. 進捗に合わせて画面（スタンプ台紙）の表示を更新
        Object.keys(progress).forEach(spotId => {
            if (progress[spotId]) {
                const element = document.getElementById(spotId);
                if (element) element.classList.add('active'); // 獲得済みのスタイルを適用
            }
        });
    </script>
</body>
</html>
